# Archon Website — local development environment
# Copy this file to .env.local and add real values only where required.

# Sanity CMS (matches studio/archon-website-cms/sanity.config.ts)
NEXT_PUBLIC_SANITY_PROJECT_ID=iwbdc0fm
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-07-13

# Optional: enable a real Archon AI backend instead of the built-in development fallback.
# Do not commit a real key.
# ARCHON_AI_BACKEND_URL=https://your-secure-backend.example.com
# ARCHON_AI_API_KEY=replace_with_a_server_side_secret

# Website lead capture via Resend. Add real values only to .env.local and Vercel.
# The sender address must be verified in the Resend account before production use.
# RESEND_API_KEY=re_replace_with_private_resend_key
# RESEND_FROM_EMAIL=Archon Website <enquiries@archonsolution.in>
# LEAD_EMAIL_TO=info@archonsolution.com
